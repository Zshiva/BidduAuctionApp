<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auction App - Register</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        .navbar {
            background-color: dodgerblue;
            text-align: center;
            padding: 10px;
            color: white;
            font-size: 24px;
        }

        .signup-container {
            background: linear-gradient(45deg, blueviolet, lightgreen);
            max-width: 500px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            text-align: left;
        }

        h2 {
            text-align: left;
        }

        label {
            display: block;
            margin-bottom: 5px;
            text-align: left;
        }

        input[type="text"],
        input[type="email"],
        input[type="tel"] {
            width: 90%;
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
            margin-bottom: 20px;
        }

        button[type="submit"] {
            background-color: dodgerblue;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 3px;
            cursor: pointer;
        }

        button[type="submit"]:hover {
            background-color: #45a049;
        }

        .popup {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%);
            background: #90ee90;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            opacity: 0;
            pointer-events: none;
            transition: 0.5s;
        }

        .popup.show {
            opacity: 1;
            pointer-events: auto;
        }
    </style>
</head>

<body>
<div class="navbar">
    Register for Auction App
</div>
<div class="signup-container">

    <form id="signup-form" method="post" action="/users/register">

        <div class="form-group">
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" required>
        </div>
        <div class="form-group">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" required>
        </div>
        <div class="form-group">
            <label for="contact">Contact:</label>
            <input type="tel" id="contact" name="contact" required>
        </div>
        <div class="form-group">
            <label for="address">Address:</label>
            <input type="text" id="address" name="address" required>
        </div>
        <div class="form-group">
            <label for="role">Role:</label>
            <input type="radio" id="seller" name="roles" value="seller" required> Seller
            <input type="radio" id="bidder" name="roles" value="bidder" required> Bidder
        </div>
        <br>

        <div class="form-group">
            <button type="submit">Register</button>
        </div>
    </form>

    <div class="popup" id="success-popup">
        <p>Signup successful!</p>
    </div>
</div>

<script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('signup-form');
            const name = document.getElementById('name');
            const email = document.getElementById('email');
            const contact = document.getElementById('contact');
            const address = document.getElementById('address');
            const roleSeller = document.getElementById('seller');
            const roleBidder = document.getElementById('bidder');

            form.addEventListener('submit', function (event) {
                let isValid = true;

                // Validate name
                if (name.value.trim() === '') {
                    alert('Please enter your name.');
                    isValid = false;
                }

                // Validate email
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRegex.test(email.value)) {
                    alert('Please enter a valid email address.');
                    isValid = false;
                }

                // Validate contact number
                const contactRegex = /^\d{10}$/;
                if (!contactRegex.test(contact.value)) {
                    alert('Please enter a valid 10-digit contact number.');
                    isValid = false;
                }

                // Validate address
                if (address.value.trim() === '') {
                    alert('Please enter your address.');
                    isValid = false;
                }

                // Validate role (either seller or bidder must be selected)
                if (!roleSeller.checked && !roleBidder.checked) {
                    alert('Please select a role (Seller or Bidder).');
                    isValid = false;
                }

                if (!isValid) {
                    event.preventDefault(); // Prevent form submission if validation fails
                }
            });
        });
    </script>

</body>

</html>
